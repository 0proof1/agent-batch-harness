include LICENSE README.md README.ko.md CHANGELOG.md CONTRIBUTING.md SECURITY.md CODE_OF_CONDUCT.md SUPPORT.md GOVERNANCE.md PUBLICATION_POLICY.md
recursive-include agents *.md
recursive-include skills *.md
recursive-include docs *.md
recursive-include examples *.md *.tsv *.txt *.json *.py
recursive-include tools *.py
recursive-include .github *.md *.yml *.yaml
prune examples/*/_batches/run-logs
global-exclude __pycache__ *.py[cod] *.tsv.lock
